// Hoop v2 — Prisma Schema
// Spec Reference: HOOP_REDESIGN_SPEC.md v2.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum BookingStatus {
  pending   // Organizer submitted — waiting for venue confirmation
  approved  // Venue owner confirmed the booking
  rejected  // Venue owner denied the booking
  cancelled // Organizer withdrew the request
}

enum AttendeeStatus {
  pending
  accepted
  declined
  maybe
}

enum TaskStatus {
  pending
  in_progress
  done
}

/// Whether this is a small (house-party scale, pin on map) or big
/// (venue-backed, conference scale) event. Locked after creation.
enum EventSize {
  small // House party, dinner, study group — user pins location on map
  big   // Wedding, gala, conference — user selects from venue listings
}

/// Lifecycle of a user's venue listing application reviewed by an admin.
enum ApplicationStatus {
  pending  // Submitted, waiting for admin review
  approved // Admin approved — venue auto-created
  rejected // Admin rejected — reason provided
}

/// All categories of in-app / email notifications the system emits.
enum NotificationType {
  event_created       // "You've been invited to [Event Name]!"
  event_updated       // "Details for [Event Name] have been updated"
  event_cancelled     // "[Event Name] has been cancelled"
  event_reminder      // "Reminder: [Event Name] is in X days!"
  venue_app_submitted // "Your venue application has been submitted"
  venue_app_approved  // "Your venue '[Name]' has been approved!"
  venue_app_rejected  // "Your venue application was not approved"
  booking_request     // "New booking request for your venue '[Name]'"
  booking_approved    // "Your venue booking has been confirmed!"
  booking_rejected    // "Your venue booking was declined"
  rsvp_update         // "X new RSVPs for your event"
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  userId       Int      @id @default(autoincrement())
  username     String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())

  // Relations
  userRoles       UserRole[]
  organizedEvents Event[]        @relation("EventOrganizer")
  eventMembers    EventMember[]
  notifications   Notification[]
  venues          Venue[]

  // Venue application relations (as applicant and as admin reviewer)
  venueApplications         VenueApplication[] @relation("VenueApplicant")
  reviewedVenueApplications VenueApplication[] @relation("VenueReviewer")

  @@map("users")
}

model Role {
  roleId   Int    @id @default(autoincrement())
  roleName String @db.VarChar(50)

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id     Int @id @default(autoincrement())
  userId Int
  roleId Int

  user User @relation(fields: [userId], references: [userId])
  role Role @relation(fields: [roleId], references: [roleId])

  @@unique([userId, roleId])
  @@map("user_roles")
}

model EventType {
  eventTypeId Int    @id @default(autoincrement())
  typeName    String @db.VarChar(100)

  events Event[]

  @@map("event_types")
}

model Event {
  eventId      Int       @id @default(autoincrement())
  userId       Int
  eventTitle   String    @db.VarChar(200)
  eventTypeId  Int
  eventDate    DateTime  @db.Date
  eventTime    DateTime  @db.Time
  eventEndTime DateTime  @db.Time
  budget       Decimal?  @db.Decimal(10, 2)
  createdAt    DateTime  @default(now())

  // v2 additions ────────────────────────────────────────────────────────────
  /// Locked after creation. small = pin on map; big = venue from listings.
  eventSize       EventSize
  description     String?   @db.Text

  // Small-event location (null for big events)
  locationLat     Decimal?  @db.Decimal(10, 7)
  locationLng     Decimal?  @db.Decimal(10, 7)
  locationAddress String?   @db.VarChar(500) // Reverse-geocoded human-readable address
  locationLabel   String?   @db.VarChar(200) // User's custom label e.g. "My apartment"

  // Optional metadata
  expectedGuests Int?
  dressCode      String?   @db.VarChar(50)  // Casual / Semi-formal / Formal / Themed
  specialNotes   String?   @db.Text

  // Reminder tracking — null means reminder hasn't been sent yet
  reminderSentAt DateTime?
  // ─────────────────────────────────────────────────────────────────────────

  // Relations
  organizer     User          @relation("EventOrganizer", fields: [userId], references: [userId])
  eventType     EventType     @relation(fields: [eventTypeId], references: [eventTypeId])

  venueBookings VenueBooking[]
  attendees     Attendee[]
  eventMembers  EventMember[]
  checklists    Checklist[]
  agenda        Agenda[]
  expenses      Expense[]
  notifications Notification[]

  @@map("events")
}

model Venue {
  venueId      Int     @id @default(autoincrement())
  name         String  @db.VarChar(150)
  location     String  @db.VarChar(255)
  capacity     Int
  contactEmail String  @db.VarChar(150)
  ownerId      Int?    // Links to a User if venue owner has a platform account

  // v2 additions ────────────────────────────────────────────────────────────
  /// Admin can deactivate without deleting (soft-delete pattern).
  isActive    Boolean  @default(true)
  description String?  @db.Text
  imageUrls   String[] @default([]) // Array of image URLs (Postgres native array)
  priceRange  String?  @db.VarChar(50)  // "$" | "$$" | "$$$"
  amenities   String[] @default([])     // e.g. ["WiFi", "Parking", "Sound System"]
  // ─────────────────────────────────────────────────────────────────────────

  owner           User?          @relation(fields: [ownerId], references: [userId])
  bookingRequests VenueBooking[]

  @@map("venues")
}

model VenueBooking {
  bookingId   Int           @id @default(autoincrement())
  venueId     Int
  eventId     Int           @unique // One active venue booking per event
  status      BookingStatus @default(pending)
  requestedAt DateTime      @default(now())
  respondedAt DateTime?     // Timestamp when venue owner acted
  notes       String?       @db.Text // Venue owner's reply or reason for rejection

  venue Venue @relation(fields: [venueId], references: [venueId])
  event Event @relation(fields: [eventId], references: [eventId])

  @@map("venue_bookings")
}

/// Venue listing application submitted by a user and reviewed by an admin.
/// On approval, a Venue record is auto-created and the applicant gains the
/// venue_owner role.
model VenueApplication {
  applicationId   Int               @id @default(autoincrement())
  userId          Int               // Applicant
  venueName       String            @db.VarChar(150)
  venueLocation   String            @db.VarChar(255)
  venueCapacity   Int
  contactEmail    String            @db.VarChar(150)
  description     String?           @db.Text // Why the user wants to list this venue
  status          ApplicationStatus @default(pending)
  reviewedBy      Int?              // Admin who reviewed
  submittedAt     DateTime          @default(now())
  reviewedAt      DateTime?
  rejectionReason String?           @db.Text // Required when rejecting

  applicant User  @relation("VenueApplicant", fields: [userId], references: [userId])
  reviewer  User? @relation("VenueReviewer", fields: [reviewedBy], references: [userId])

  @@map("venue_applications")
}

model Attendee {
  attendeeId   Int            @id @default(autoincrement())
  eventId      Int
  name         String         @db.VarChar(150)
  email        String         @db.VarChar(150)
  status       AttendeeStatus @default(pending)
  responseTime DateTime?

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("attendees")
}

model EventMember {
  id      Int    @id @default(autoincrement())
  eventId Int
  userId  Int
  role    String @db.VarChar(50)

  event Event @relation(fields: [eventId], references: [eventId])
  user  User  @relation(fields: [userId], references: [userId])

  @@unique([eventId, userId])
  @@map("event_members")
}

model Checklist {
  checklistId Int     @id @default(autoincrement())
  eventId     Int
  description String  @db.Text
  isDone      Boolean @default(false)

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("checklist")
}

model Agenda {
  agendaId    Int      @id @default(autoincrement())
  eventId     Int
  title       String   @db.VarChar(150)
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("agenda")
}

model Expense {
  expenseId     Int     @id @default(autoincrement())
  eventId       Int
  name          String  @db.VarChar(150)
  category      String  @db.VarChar(100)
  estimatedCost Decimal @db.Decimal(10, 2)
  actualCost    Decimal @db.Decimal(10, 2)

  event Event @relation(fields: [eventId], references: [eventId])

  @@map("expenses")
}

/// Enhanced notification model — typed, optionally linked to an event,
/// and carrying a structured JSON metadata payload for rich rendering.
model Notification {
  notificationId Int              @id @default(autoincrement())
  userId         Int
  eventId        Int?             // Optional link to a related event
  type           NotificationType
  title          String           @db.VarChar(200)
  message        String           @db.Text
  metadata       Json?            // Structured payload (map URL, agenda, venue details, etc.)
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [userId])
  event Event? @relation(fields: [eventId], references: [eventId])

  @@map("notifications")
}
